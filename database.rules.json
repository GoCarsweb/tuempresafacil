{
  "rules": {
    "tarjetas": {
      ".read": true,
      ".write": "auth != null"
    },
    "clients": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "bookings": {
      ".read": true,
      "$date": {
        "$slot": {
          ".write": "auth != null || !data.exists()",
          ".validate": "newData.hasChildren(['nombre','telefono'])"
        }
      }
    }
  }
}
